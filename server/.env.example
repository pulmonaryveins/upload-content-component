# Copy this file to .env and fill in your values.
# NEVER commit .env — it is gitignored.

# Transloadit — https://transloadit.com/accounts/credentials
TRANSLOADIT_KEY=your_transloadit_auth_key
TRANSLOADIT_AUTH_SECRET=your_transloadit_auth_secret
TRANSLOADIT_TEMPLATE_ID=your_template_id

# Google — https://console.cloud.google.com/apis/credentials
GOOGLE_API_KEY=your_google_api_key

# Facebook — App ID is a public OAuth identifier kept in
# src/environments/environment.ts (not this file). No server-side secret needed.

# Comma-separated list of Angular app origins that may call this server
ALLOWED_ORIGINS=http://localhost:4200

# Port for this server
PORT=3000
